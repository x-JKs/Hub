# Bungie app credentials. Vite bakes these into the build at compile time
# (import.meta.env.VITE_*), so an official release works out of the box.
#
# Copy this file to ".env" (which is gitignored, never committed) and fill in
# your own values before building. Create a Bungie app at:
#   https://www.bungie.net/en/Application
#
# If left unset, the app will prompt the user to enter their own API key on
# first run.

VITE_BUNGIE_API_KEY=your-bungie-api-key-here
VITE_OAUTH_CLIENT_ID=your-oauth-client-id-here
VITE_OAUTH_CLIENT_SECRET=your-oauth-client-secret-here
